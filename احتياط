<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Sorry 🤍</title>

<style>

*{
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
margin:0;
height:100vh;
overflow:hidden;
display:flex;
align-items:center;
justify-content:center;
background:linear-gradient(135deg,#ffe6f2,#ffffff);
}


.container{
width:90%;
max-width:420px;
text-align:center;
}


.card{
background:white;
padding:25px;
border-radius:25px;
box-shadow:0 10px 30px #ffc5df;
}


button{
border:0;
padding:14px 28px;
border-radius:30px;
font-size:18px;
cursor:pointer;
background:#ff9dcc;
color:white;
}


.start{
animation:pulse 1.5s infinite;
}


@keyframes pulse{

50%{
transform:scale(1.1);
}

}


.buttons{
display:flex;
justify-content:center;
gap:15px;
margin-top:20px;
}


.no{
background:#999;
position:absolute;
}



h1{
color:#ff75b5;
}


p{
font-size:18px;
line-height:2;
}



.heart{

position:fixed;
bottom:-30px;
font-size:25px;
animation:up 5s linear forwards;

}



@keyframes up{

from{
transform:translateY(0);
opacity:1;
}

to{
transform:translateY(-110vh);
opacity:0;
}

}


</style>

</head>


<body>


<div class="container">


<div id="first">

<button class="start" onclick="openPage()">
اضغطي هنا 🤍
</button>

</div>



<div id="second" style="display:none">


<div class="card">

<h1>
سامحيني 🤍
</h1>


<p>
أعتذر منك وأتمنى تقبلين اعتذاري.
</p>


<div class="buttons">


<button onclick="forgive()">
سامحتك 🤍
</button>


<button id="no" class="no">
ما أسامح 😔
</button>


</div>

</div>


</div>



</div>




<script>


function openPage(){

document.getElementById("first").style.display="none";

document.getElementById("second").style.display="block";

createHeart();

}



function createHeart(){

setInterval(function(){

let h=document.createElement("div");

h.className="heart";

h.innerHTML="🤍";

h.style.left=Math.random()*100+"vw";


document.body.appendChild(h);


setTimeout(function(){

h.remove();

},5000);


},500);

}




let noButton=document.getElementById("no");


noButton.addEventListener("mouseover",function(){

noButton.style.left=Math.random()*250+"px";

noButton.style.top=Math.random()*200+"px";

});



function forgive(){

document.getElementById("second").innerHTML=`

<div class="card">

<h1>🤍</h1>

<p>
أعتذر عن اللي صار، وأتمنى تسامحيني، وأتمنى تعطيني فرصة أصلح اللي صار. 🤍
</p>

<p>
انتظري 7 ثواني...
</p>

</div>

`;


setTimeout(function(){

document.getElementById("second").innerHTML=`

<div class="card">

<h1>🎁</h1>

<p>
تفتحين الهدية؟
</p>

<button onclick="gift()">
فتح 🤍
</button>

</div>

`;

},7000);


}




function gift(){

document.getElementById("second").innerHTML=`

<div class="card">

<h1>
🐱🩷
</h1>

<p>
I'm Sorry 🤍
</p>

</div>

`;

}



</script>


</body>

</html>
